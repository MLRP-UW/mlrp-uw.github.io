---
import site from "../data/site.json";

const currentPath = Astro.url.pathname;
---

<nav class="w-full border-b border-divider bg-cream">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2 no-underline">
      <img src="/Frame 9.svg" alt={site.shortName} class="h-10 w-10" />
      <span class="font-pixel text-2xl font-medium tracking-tight text-accent">Machine Learning Reading Program</span>
    </a>
    <div class="flex items-center gap-6">
      {site.navigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-sm transition-colors no-underline",
            currentPath === item.href || currentPath === item.href + "/"
              ? "font-medium text-text"
              : "text-text-muted hover:text-text",
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>
